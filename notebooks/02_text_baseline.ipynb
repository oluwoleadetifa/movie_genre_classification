import pandas as pd
from sklearn.model_selection import train_test_split

from src.data.preprocess_text import preprocess_text_dataframe
from src.features.tfidf_features import fit_transform_tfidf
from src.models.text_models import (
    build_tfidf_baseline_model,
    train_text_model,
    predict_text_model
)

df = pd.read_csv("data/processed/movies.csv")
df.head()

# Cell 3: inspect columns
print(df.columns)

# Cell 4: preprocess text
df = preprocess_text_dataframe(
    df,
    text_column="overview",
    output_column="clean_text"
)

df[["overview", "clean_text"]].head()

# Cell 5: define genre columns
genre_cols = [
    "Action",
    "Comedy",
    "Drama",
    "Thriller",
    "Romance"
]

# Cell 6: split data
train_df, test_df = train_test_split(
    df,
    test_size=0.2,
    random_state=42
)

train_df, val_df = train_test_split(
    train_df,
    test_size=0.25,
    random_state=42
)

# Cell 7: create TF-IDF features
tfidf_outputs = fit_transform_tfidf(
    train_df["clean_text"],
    val_df["clean_text"],
    test_df["clean_text"],
    max_features=10000,
    ngram_range=(1, 2)
)

X_train = tfidf_outputs["X_train"]
X_val = tfidf_outputs["X_val"]
X_test = tfidf_outputs["X_test"]

y_train = train_df[genre_cols].values
y_val = val_df[genre_cols].values
y_test = test_df[genre_cols].values

# Cell 8: train model
model = build_tfidf_baseline_model()
model = train_text_model(model, X_train, y_train)

# Cell 9: make predictions
y_val_pred, y_val_prob = predict_text_model(model, X_val)
y_test_pred, y_test_prob = predict_text_model(model, X_test)
